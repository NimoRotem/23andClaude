# genomeClaw environment variables
# Copy this to .env and fill in your values

# AI-powered report generation (optional)
ANTHROPIC_API_KEY=""
AI_REPORT_MODEL="claude-sonnet-4-20250514"

# OpenAI (optional, for alternative AI features)
OPENAI_API_KEY=""

# Authentication
JWT_SECRET="change-me-to-a-random-string"
GENOMICS_ADMIN_PASSWORD="changeme"

# Storage paths (defaults shown)
GENOMICS_DATA_DIR="/data"
GENOMICS_SCRATCH_DIR="/scratch"

# Server
GENOMICS_PORT=8600
REDIS_URL="redis://localhost:6379/0"

# Claude Code integration (optional)
CLAUDE_CMD=""
GENOMICS_WORK_DIR=""
